# =========================
# GEST (Banco SQL Server)
# =========================
# REGRA DE OURO:
# O servidor 192.168.0.100 e SOMENTE LEITURA/CONSULTA.
# Nunca usar usuario com permissao de INSERT, UPDATE, DELETE, CREATE, DROP ou ALTER.
# Este projeto nao deve criar, alterar ou apagar nenhum dado no GEST.
GEST_DB_SERVER=192.168.0.100
GEST_DB_USER=usuario_somente_leitura
GEST_DB_PASSWORD=senha_aqui
GEST_DB_NAME=gest

# =========================
# SERASA
# =========================
SERASA_ENV=sandbox
SERASA_BASE_URL=
SERASA_CLIENT_ID=
SERASA_CLIENT_SECRET=

# =========================
# APP
# =========================
APP_ENV=development
